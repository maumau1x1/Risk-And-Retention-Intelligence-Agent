# =============================================================================
# Risk & Retention Intelligence Agent — Root Environment Template
# Copy to .env and fill in values. NEVER commit real secrets.
# =============================================================================

# --- MCP Server (Python backend) ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
MCP_SERVER_URL=http://localhost:8080/mcp
MCP_SERVER_PUBLIC_URL=https://your-ngrok-or-azure-url.example.com/mcp

# --- Microsoft Entra ID (OAuth 2.1 for MCP + write operations) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_API_SCOPE=api://your-mcp-app-id/.default
OAUTH_REDIRECT_URI=https://teams.microsoft.com/api/platform/v1.0/oAuthRedirect

# --- Microsoft Fabric IQ ---
FABRIC_WORKSPACE_ID=
FABRIC_SEMANTIC_MODEL_ID=
FABRIC_IQ_PROJECT_CONNECTION_ID=
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1
# Optional: direct Fabric IQ MCP hub endpoint (preview)
FABRIC_IQ_MCP_URL=

# --- Risk ontology / semantic layer (logical names, not secrets) ---
RISK_ONTOLOGY_NAME=EnterpriseRiskRetention
SEMANTIC_MODEL_NAME=RiskRetentionMetrics

# --- Agent Toolkit provisioning ---
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=-dev
