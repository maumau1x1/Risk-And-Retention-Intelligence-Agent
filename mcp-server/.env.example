# MCP Server runtime — copy to .env (never commit secrets)

MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# Microsoft Entra ID — OAuth 2.1 resource server
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_API_AUDIENCE=api://your-mcp-app-id

# Microsoft Fabric IQ
FABRIC_WORKSPACE_ID=
FABRIC_SEMANTIC_MODEL_ID=
FABRIC_IQ_PROJECT_CONNECTION_ID=
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1

# Development: use mock data when Fabric is not configured
USE_MOCK_FABRIC_DATA=true
